PORT=3001

# Utiliser "mock" pour les donnees locales ou "mysql" pour interroger MySQL.
RH_DATA_SOURCE=mock

# Configuration MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=iecbman2020
MYSQL_CONNECTION_LIMIT=10
MYSQL_SSL=false

# Noms des vues SQL attendues par le backend.
MYSQL_VIEW_EFFECTIF=vw_rh_effectif
MYSQL_VIEW_DEPARTS=vw_rh_departs
MYSQL_VIEW_BADGES=vw_rh_badges
MYSQL_VIEW_ENTITES=vw_rh_entites

# Optionnel: personnaliser le sel de hachage du compte local.
RH_PASSWORD_SALT=rh-direction-salt
